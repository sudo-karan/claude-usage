<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient android:type="linear" android:angle="270"
                android:startColor="#FF211C15" android:endColor="#FF17130D" />
            <stroke android:width="1dp" android:color="#26FFFFFF" />
        </shape>
    </item>
    <!-- Session bar -->
    <item android:left="20dp" android:right="20dp" android:top="44dp" android:bottom="64dp">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#33FFFFFF" />
        </shape>
    </item>
    <item android:left="20dp" android:right="150dp" android:top="44dp" android:bottom="64dp">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#E0875C" />
        </shape>
    </item>
    <!-- Weekly bar -->
    <item android:left="20dp" android:right="20dp" android:top="76dp" android:bottom="32dp">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#33FFFFFF" />
        </shape>
    </item>
    <item android:left="20dp" android:right="190dp" android:top="76dp" android:bottom="32dp">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#7E8AE6" />
        </shape>
    </item>
</layer-list>
